# Main site (public) – use in config.js
NEXT_PUBLIC_SUPABASE_URL=https://uucpwlklqacgfywyfcht.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx

# Admin – same URL, different key. Use in admin/config.js only (never expose in public site).
# Get from: Supabase Dashboard → Project Settings → API → "service_role" (secret, not anon/publishable)
SUPABASE_URL=https://uucpwlklqacgfywyfcht.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack (optional) – use PUBLIC key only in frontend
PAYSTACK_PUBLIC_KEY=pk_test_xxxx
